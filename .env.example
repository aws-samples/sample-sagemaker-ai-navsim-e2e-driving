# ============================================================
# SageMaker AI ML Pipeline - Environment Configuration
# ============================================================
#
# Copy this file to create your .env:
#   cp .env.example .env
#
# .env is listed in .gitignore, so it will not be committed to the repository.
#
# For the Japanese version of this file, see .env.example.ja
# ============================================================

# --- Region Configuration ---
# AWS region to deploy to (default: us-east-1)
AWS_DEFAULT_REGION="us-east-1"

# --- GitHub Repository Integration (optional) ---
# If you do not need GitHub integration, leave the following values empty or comment them out.
# Without GitHub integration, the repository is still deployed to the Notebook via S3.
#
# GitHub repository URL to link to the Notebook (username is auto-extracted from the URL)
# Example: https://github.com/your-username/your-repo.git
GITHUB_REPO="https://github.com/your-username/sagemaker-ai-ml-pipeline.git"

# GitHub Personal Access Token (PAT)
# Classic PAT: requires the `repo` scope
# Fine-grained PAT: requires Contents permission (Read-only) on the target repository
# Create one at: https://github.com/settings/tokens
GITHUB_PAT="your-github-personal-access-token"

# --- VPC Configuration (optional) ---
# Leave ENABLE_VPC=false if you do not want to use a VPC.
# ENABLE_VPC=true
#
# To use an existing VPC, specify VPC_ID, SUBNET_IDS, and SECURITY_GROUP_ID.
# If left empty, a new VPC is created.
# VPC_ID="vpc-xxxxxxxxxxxxxxxxx"
# SUBNET_IDS="subnet-xxxxxxxxxxxxxxxxx,subnet-yyyyyyyyyyyyyyyyy"
# SECURITY_GROUP_ID="sg-xxxxxxxxxxxxxxxxx"
#
# Set to false if VPC Endpoints already exist in the existing VPC.
# CREATE_VPC_ENDPOINTS=true

# --- SageMaker Unified Studio Configuration (optional) ---
# If you do not use Unified Studio, leave the following values empty or comment them out.
#
# ARN of the IAM Identity Center (SSO) instance
# Check: AWS Console → IAM Identity Center → Settings → Instance ARN
UNIFIED_STUDIO_IDC_INSTANCE_ARN="arn:aws:sso:::instance/ssoins-xxxxxxxxxxxx"

# Email addresses of SSO users to register as project owners / domain administrators
# deploy-foundation.sh adds them as domain administrators; deploy-project.sh adds them as project owners
# Multiple users can be specified comma-separated: "user1@example.com,user2@example.com"
UNIFIED_STUDIO_SSO_USERS="user@example.com"

# --- Hugging Face Configuration (optional) ---
# When running the CARLA demo, timm downloads pretrained weights from the Hugging Face Hub.
# Setting HF_TOKEN relaxes rate limits and enables faster downloads.
# The demo works without this, but a warning will be shown.
# Create one at: https://huggingface.co/settings/tokens
# HF_TOKEN="hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
