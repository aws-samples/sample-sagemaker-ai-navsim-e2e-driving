# ============================================================
# SageMaker AI ML Pipeline - 環境設定ファイル
# ============================================================
#
# このファイルをコピーして .env を作成してください:
#   cp .env.example.ja .env
#
# .env は .gitignore に含まれているため、リポジトリにはコミットされません。
#
# 英語版は .env.example を参照してください。
# ============================================================

# --- リージョン設定 ---
# デプロイ先の AWS リージョン (デフォルト: us-east-1)
AWS_DEFAULT_REGION="us-east-1"

# --- GitHub リポジトリ設定 (オプション) ---
# GitHub 連携が不要な場合は、以下の設定をすべて空にするか、コメントアウトしてください。
# GitHub 連携なしでもリポジトリは S3 経由で Notebook に自動配置されます。
#
# Notebook に連携する GitHub リポジトリの URL (ユーザー名は URL から自動抽出)
# 例: https://github.com/your-username/your-repo.git
GITHUB_REPO="https://github.com/your-username/sagemaker-ai-ml-pipeline.git"

# GitHub Personal Access Token (PAT)
# Classic PAT の場合: repo スコープが必要
# Fine-grained PAT の場合: 対象リポジトリの Contents 権限 (Read-only)
# 取得方法: https://github.com/settings/tokens
GITHUB_PAT="your-github-personal-access-token"

# --- VPC 設定 (オプション) ---
# VPC を使用しない場合は ENABLE_VPC=false のままにしてください。
# ENABLE_VPC=true
#
# 既存 VPC を使用する場合は VPC_ID, SUBNET_IDS, SECURITY_GROUP_ID を指定。
# 空の場合は新規 VPC を作成します。
# VPC_ID="vpc-xxxxxxxxxxxxxxxxx"
# SUBNET_IDS="subnet-xxxxxxxxxxxxxxxxx,subnet-yyyyyyyyyyyyyyyyy"
# SECURITY_GROUP_ID="sg-xxxxxxxxxxxxxxxxx"
#
# 既存 VPC に VPC Endpoint が既にある場合は false に設定。
# CREATE_VPC_ENDPOINTS=true

# --- SageMaker Unified Studio 設定 (オプション) ---
# Unified Studio を使用しない場合は、以下の設定をすべて空にするか、コメントアウトしてください。
#
# IAM Identity Center (SSO) インスタンスの ARN
# AWS コンソール → IAM Identity Center → Settings → Instance ARN で確認できます
UNIFIED_STUDIO_IDC_INSTANCE_ARN="arn:aws:sso:::instance/ssoins-xxxxxxxxxxxx"

# プロジェクトオーナー / ドメイン管理者として登録する SSO ユーザーのメールアドレス
# deploy-foundation.sh でドメイン管理者、deploy-project.sh でプロジェクトオーナーとして追加されます
# カンマ区切りで複数指定可: "user1@example.com,user2@example.com"
UNIFIED_STUDIO_SSO_USERS="user@example.com"

# --- Hugging Face 設定 (オプション) ---
# CARLA デモ実行時に timm が HuggingFace Hub から事前学習済み重みをダウンロードします。
# HF_TOKEN を設定すると、レート制限の緩和と高速ダウンロードが有効になります。
# 未設定でも動作しますが、Warning が表示されます。
# 取得方法: https://huggingface.co/settings/tokens
# HF_TOKEN="hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
